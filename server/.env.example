# ============================================================
# codeflicker-webclaw 环境变量配置
# 复制此文件为 .env.local 并填入你的实际值
# cp .env.local.example .env.local
# ============================================================

# ---------- 部署模式说明 ----------
#
# 模式 A：Web 服务和 flickcli 在同一台机器（推荐）
#   → 只需配置 FLICKCLI_SSH_HOME
#   → 代码会自动检测本地 flickcli 安装，无需 SSH
#
# 模式 B：Web 服务和 flickcli 在不同机器
#   → 需要配置所有 SSH 相关变量
#   → Web 服务通过 SSH 连接到 flickcli 所在的机器

# ---------- 通用配置 ----------

# 远程用户家目录（用于将 ~ 展开为绝对路径）
FLICKCLI_SSH_HOME=/Users/zhaoshuai11

# ---------- 模式 B：SSH 连接配置（同机部署可忽略） ----------

# flickcli 所在服务器的 IP
# FLICKCLI_SSH_HOST=192.168.1.100
# SSH 端口
# FLICKCLI_SSH_PORT=22
# SSH 用户名
# FLICKCLI_SSH_USER=zhangsan
# SSH 密钥密码（如果你的 key 有密码保护）
# FLICKCLI_SSH_PASSPHRASE=

# ---------- 强制指定模式（通常不需要，代码会自动检测） ----------

# 设为 local 则强制本地模式，跳过 SSH
# FLICKCLI_MODE=local

# ---------- 服务端口 ----------
# 后端端口（默认 3001）
# PORT=3001
# CORS 允许来源（默认 http://localhost:3000）
# CORS_ORIGIN=http://localhost:3000

# ---------- 前端 Vite 环境变量（前缀 VITE_） ----------
# API 基础路径（通常留空，由 Vite proxy 处理）
# VITE_BASE_PATH=
